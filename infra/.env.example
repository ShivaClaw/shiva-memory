# Environment Variables for Docker Compose
# DO NOT COMMIT ACTUAL VALUES TO GIT
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (not tracked by git)
# 2. Fill in values from TOKENS&KEYS Google Sheet (see TOOLS.md)
# 3. Never commit .env or expose values in logs
# 4. When deploying, set variables before docker-compose up

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-...

# Google API Key (for Gemini models)
GOOGLE_API_KEY=AIzaSy...

# Maton API Key (for OAuth-gated Google Drive/Sheets/Gmail access)
MATON_API_KEY=<see TOKENS&KEYS spreadsheet>

# Hostinger API Token (for VPS snapshots)
HOSTINGER_API_TOKEN=<see TOKENS&KEYS spreadsheet>

# xAI Grok API Key (optional, for Grok models)
XAI_API_KEY=xai-...

# OpenRouter API Key (optional, for multi-model routing)
OPENROUTER_API_KEY=sk-or-...

# GitHub Token (optional, for GitHub API access)
# Note: Prefer SSH keys over PATs when possible
GITHUB_TOKEN=ghp_...

# LCM Database Path
LCM_DB_PATH=~/.openclaw/lcm.db

# Memory Paths
MEMORY_PATH=/data/.openclaw/workspace/memory
LAYER0_PATH=/data/.openclaw/workspace/memory/layer0

# Qdrant Configuration
QDRANT_HOST=memory-qdrant
QDRANT_PORT=6333

# FalkorDB Configuration
FALKORDB_HOST=memory-falkordb
FALKORDB_PORT=6379

# Traefik Configuration
TRAEFIK_DOMAIN=trident-memory.com
TRAEFIK_EMAIL=brandongkirksey@gmail.com

# Reference: TOKENS&KEYS
# Location: Google Docs (canonical source for all API keys)
# Last updated: 2026-04-02
# Access: brandongkirksey@gmail.com
